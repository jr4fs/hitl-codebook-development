{
  "compilerOptions": {
    "baseUrl": "../",
    "paths": {
      "@common/types/*": ["common/src/types/*"],
      "@common/*": ["common/src/*"]
    },
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "moduleDetection": "force",
        "rootDir": "../",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "../common/src"]
}

