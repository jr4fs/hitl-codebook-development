# ============================================================================
#  annotation_tool — local environment (single source of truth)
#
#    cp .env.example .env    then fill in the blanks.
#
#  This ONE file is read by every service:
#    - docker compose        (all services, via ${VAR} interpolation)
#    - backend  (Node)       dotenv -> repo-root .env
#    - pybackend (FastAPI)   load_dotenv -> repo-root .env
#    - frontend (Vite)       reads VITE_* only (envDir = repo root)
#
#  Only VITE_* vars reach the browser — keep all secrets un-prefixed.
#  .env is git-ignored. NEVER commit real secrets.
# ============================================================================

# ---- MongoDB ----
# Native dev (services on host):     mongodb://localhost:27017
# Docker compose (local overlay):    mongodb://mongo:27017
# MongoDB Atlas (shared/cloud):      mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_CONN_STRING=mongodb://localhost:27017
DB_NAME=annotationTool
USER_DETAILS_COLLECTION_NAME=UserDetails
TASKS_COLLECTION_NAME=TaskDetails
ANNOTATION_COLLECTION_NAME=AnnotationDetails

# ---- Auth (JWT) ----
# Generate each with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
# Public self-service signup. Keep false and provision users with
# backend/scripts/createUser.ts for credentialed deployments.
ALLOW_SIGNUP=true

# ---- LLM inference ----
LLM_PROVIDER=openrouter                 # openrouter | ollama
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_APP_NAME=Annotation Tool
OPENROUTER_SITE_URL=http://localhost
# Optional: override friendly-key -> OpenRouter-slug map (JSON). See openrouter.ai/models.
# OPENROUTER_MODEL_MAP={"gemma3:1b":"google/gemma-3-4b-it"}

# ---- Embeddings (representative + coverage sampling) ----
EMBEDDINGS_PROVIDER=openai              # local | openai | bedrock
# If openai:
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1     # override for Azure/proxy
# If bedrock (AWS): BEDROCK_EMBEDDING_MODEL, BEDROCK_REGION, and AWS creds/instance role.
# BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ---- App behaviour ----
# DEFAULT = full representative + coverage sampling; UI_DEV = fast/skip (quick local tests).
APP_MODE=UI_DEV
# Max concurrent sampling jobs in pybackend (memory guard). Extra uploads queue.
MAX_CONCURRENT_SAMPLING=1
# Randomly subsample the unlabeled pool to this many rows before embedding. Empty = off.
SAMPLING_CANDIDATE_CAP=
# Default "Budget" (max samples for codebook development). Backend fallback + build-time UI default.
DEFAULT_COVERAGE_SAMPLES=15
VITE_DEFAULT_COVERAGE_SAMPLES=15
# Frontend banner: "pilot" shows the Pilot Mode banner; blank = none.
VITE_APP_MODE=

# ---- Docker compose only (ignored in native dev) ----
# Host data root shared by node + pybackend; and Caddy TLS.
DATA_DIR=./data
DOMAIN=localhost
ACME_EMAIL=internal@localhost
