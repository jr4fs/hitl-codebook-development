# Copy to terraform.tfvars and edit. `terraform apply` reads it automatically.
# terraform.tfvars is git-ignored (may contain your IP / account specifics).

region          = "us-east-1"
ssh_cidr        = "REPLACE_WITH_YOUR_IP/32" # e.g. 203.0.113.9/32  (curl ifconfig.me)
public_key_path = "~/.ssh/id_ed25519.pub"

# instance_type = "t3.medium"   # 4GB; drop to t3.small once purely on APIs
# enable_bedrock = false        # set true in the Bedrock phase to add InvokeModel to the role
