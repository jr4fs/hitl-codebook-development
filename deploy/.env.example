# Copy to repo-root .env (cp deploy/.env.example .env) and fill in.
# docker compose reads ./.env automatically. NEVER commit the real .env.

# ---- Public domain / TLS (Caddy) ----
# Domain pointed at the VM's static IP. Caddy auto-issues a Let's Encrypt cert.
# For local testing without a domain, use DOMAIN=localhost.
DOMAIN=annotate.example.org
ACME_EMAIL=you@example.org

# ---- Host data root (persistent, snapshotted disk on the VM) ----
# All uploads + sampling artifacts live here and are shared by node + pybackend.
DATA_DIR=/mnt/appdata

# ---- MongoDB Atlas ----
# Same cluster used by both Node (DB_CONN_STRING) and Python (mapped to MONGODB_URI).
DB_CONN_STRING=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=annotationTool

# Collection names (defaults match the app + setup_repo.py).
USER_DETAILS_COLLECTION_NAME=UserDetails
TASKS_COLLECTION_NAME=TaskDetails
ANNOTATION_COLLECTION_NAME=AnnotationDetails

# ---- Auth (JWT) ----
# Use long random strings, e.g. `openssl rand -hex 32` for each.
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# Public self-service signup. Keep false for credentialed deployments;
# provision accounts with: docker compose exec node npx tsx scripts/createUser.ts ...
ALLOW_SIGNUP=false

# ---- LLM inference (OpenRouter) ----
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
# Optional: override default friendly-key -> OpenRouter-slug mapping (JSON).
# Verify slugs at https://openrouter.ai/models if a model 404s.
# OPENROUTER_MODEL_MAP={"gemma3:1b":"google/gemma-3-4b-it"}
OPENROUTER_APP_NAME=Annotation Tool
OPENROUTER_SITE_URL=https://annotate.example.org

# ---- Embeddings (representative + coverage sampling) ----
# Backend for text embeddings. Default "local" runs mpnet in-process (needs ~1.5GB
# extra RAM + CPU during sampling -> 4-8GB VM). Set to "bedrock" or "openai" to
# offload embeddings to an API so the app fits a small (~2GB) VM. No quality loss.
EMBEDDINGS_PROVIDER=local
#
# --- If EMBEDDINGS_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # default if unset
# OPENAI_BASE_URL=https://api.openai.com/v1       # override for Azure/proxy
#
# --- If EMBEDDINGS_PROVIDER=bedrock (recommended on AWS; data stays in your account) ---
# BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0   # or cohere.embed-english-v3
# BEDROCK_REGION=us-east-1
# Creds: prefer the VM's IAM instance role. Otherwise set static keys:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ---- Sampling behaviour ----
# DEFAULT = full representative + coverage sampling; UI_DEV = fast/skip (see README).
APP_MODE=DEFAULT
# Max concurrent dataset-sampling jobs in pybackend (memory guard). Extra uploads
# queue (FIFO) and the UI shows their position. Raise on larger VMs (e.g. 2 on 16GB).
MAX_CONCURRENT_SAMPLING=1

# ---- Frontend banner (optional) ----
# Set to "pilot" to show the pilot banner; leave blank otherwise.
VITE_APP_MODE=
