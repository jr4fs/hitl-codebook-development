# ============================================================================
#  annotation-tool — deployment config (THE single file you edit)
#
#  1. cp deploy/config.env.example deploy/config.env
#  2. fill in the values below
#  3. run ./deploy/deploy.sh   (provisions + deploys; re-run = redeploy)
#
#  config.env is git-ignored. It is the ONE source of truth: it drives the
#  Terraform infra, the container .env on the server, and the first user.
#  JWT secrets are generated automatically (deploy/.generated.env) — don't set them.
# ============================================================================

# ---- AWS / infrastructure ----
AWS_REGION=us-east-1
AWS_PROFILE=default              # aws CLI profile to use (from `aws configure`)
INSTANCE_TYPE=t3.medium          # 4GB; drop to t3.small once purely on APIs
SSH_CIDR=auto                    # 'auto' = your current public IP; or e.g. 1.2.3.4/32
PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
ENABLE_BEDROCK=false             # true adds bedrock:InvokeModel to the instance role

# ---- Code source ----
GIT_REPO=git@github.com:chandan-m/annotation_tool.git
GIT_BRANCH=deploy-single-vm

# ---- Public domain / TLS ----
# Leave DOMAIN blank to auto-use  annotate.<elastic-ip>.sslip.io  (free HTTPS, no DNS).
# Or set your own hostname AFTER pointing its A record at the elastic IP.
DOMAIN=
ACME_EMAIL=you@example.org

# ---- MongoDB Atlas ----
DB_CONN_STRING=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=annotationTool

# ---- LLM inference ----
LLM_PROVIDER=openrouter          # openrouter | ollama
OPENROUTER_API_KEY=sk-or-...

# ---- Embeddings ----
EMBEDDINGS_PROVIDER=openai       # local | openai | bedrock
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0   # used only if provider=bedrock

# ---- App behaviour ----
ALLOW_SIGNUP=false               # keep false for credentialed deployments
APP_MODE=DEFAULT                 # DEFAULT (full sampling) | UI_DEV (fast/skip)
MAX_CONCURRENT_SAMPLING=1        # raise on bigger VMs
# Randomly subsample the unlabeled pool to this many rows BEFORE embedding, so huge
# datasets sample fast/cheap on a small VM. Empty = disabled (embed everything).
# Recommended ~15000 when using an embeddings API on a small box.
SAMPLING_CANDIDATE_CAP=

# ---- Admin account ----
# Created on deploy if email + password are set, AND this email is the ONLY account
# with access to /admin (create/manage users). It cannot be edited from the admin UI.
ADMIN_NAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
